<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Delta Issue — A Documentary Workshop Publication</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,700;0,9..144,900;1,9..144,400;1,9..144,600&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;1,8..60,400&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#17130f;
    --ink-soft:#241d16;
    --paper:#e8e0cb;
    --paper-hi:#f1ead9;
    --clay:#a63e2c;
    --clay-soft:#c05a3e;
    --river:#22404c;
    --river-deep:#152a33;
    --gold:#c99a3d;
    --charcoal:#2a2419;
    --charcoal-soft:#514736;
    --rule: rgba(42,36,25,0.18);
    --rule-dark: rgba(232,224,203,0.22);
    --maxw: 880px;
    --museum-bg:#120e0a;
    --museum-card:#1c1712;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    background:var(--paper);
    color:var(--charcoal);
    font-family:'Source Serif 4', serif;
    font-size:18px;
    line-height:1.65;
  }
  ::selection{background:var(--clay); color:var(--paper-hi);}
  h1,h2,h3,h4{
    font-family:'Fraunces', serif;
    font-weight:600;
    margin:0;
    line-height:1.05;
  }
  .eyebrow{
    font-family:'IBM Plex Mono', monospace;
    text-transform:uppercase;
    letter-spacing:.14em;
    font-size:12.5px;
    font-weight:500;
  }
  a{color:inherit;}
  img{max-width:100%;display:block;}

  /* ---------- SPINE NAV (now acts as tab bar) ---------- */
  #spine{
    position:fixed;
    top:0; left:0; bottom:0;
    width:64px;
    background:var(--ink);
    z-index:500;
    display:flex;
    flex-direction:column;
    align-items:center;
    padding:18px 0;
    border-right:1px solid rgba(232,224,203,0.08);
  }
  #spine .mark{
    width:30px;height:30px;border:1.5px solid var(--gold);border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    font-family:'IBM Plex Mono';font-size:10px;color:var(--gold);
    margin-bottom:22px; flex-shrink:0; cursor:pointer;
  }
  #spine-list{
    list-style:none; margin:0; padding:0;
    display:flex; flex-direction:column; gap:2px;
    overflow-y:auto;
    flex:1;
    scrollbar-width:none;
    width:100%;
  }
  #spine-list::-webkit-scrollbar{display:none;}
  #spine-list li a{
    display:flex; align-items:center; justify-content:center;
    height:38px; width:100%;
    text-decoration:none; cursor:pointer;
    font-family:'IBM Plex Mono'; font-size:11px; color:rgba(232,224,203,0.45);
    position:relative;
    transition:color .2s ease;
  }
  #spine-list li a:hover{color:var(--paper-hi);}
  #spine-list li a.active{color:var(--gold);}
  #spine-list li a.active::before{
    content:"";
    position:absolute; left:0; top:6px; bottom:6px; width:3px;
    background:var(--gold);
  }

  /* ---------- LAYOUT ---------- */
  main{margin-left:64px;}
  .wrap{max-width:var(--maxw); margin:0 auto; padding:0 32px;}

  /* ---------- TAB PANEL SYSTEM ---------- */
  .tab-panel{display:none;}
  .tab-panel.active{display:block; animation:fadeIn .35s ease;}
  @keyframes fadeIn{from{opacity:0; transform:translateY(6px);} to{opacity:1; transform:translateY(0);}}

  .tab-pager{
    display:flex; justify-content:space-between; align-items:center;
    padding:34px 32px 56px; max-width:var(--maxw); margin:0 auto;
    font-family:'IBM Plex Mono'; font-size:12.5px; border-top:1px solid var(--rule);
    color:var(--charcoal-soft);
  }
  [data-dark="true"] .tab-pager{border-top:1px solid var(--rule-dark); color:rgba(232,224,203,0.6);}
  .tab-pager a{text-decoration:none; cursor:pointer; display:flex; align-items:center; gap:8px;}
  .tab-pager a:hover{color:var(--clay-soft);}
  .tab-pager .p-next{margin-left:auto; text-align:right;}
  .tab-pager small{display:block; text-transform:uppercase; letter-spacing:.08em; font-size:10px; opacity:.6; margin-bottom:3px;}

  /* ---------- COVER ---------- */
  #cover{
    min-height:100vh;
    background:
      radial-gradient(ellipse at 30% 20%, rgba(166,62,44,0.35), transparent 55%),
      linear-gradient(180deg, var(--ink) 0%, var(--ink-soft) 100%);
    color:var(--paper-hi);
  }
  #cover .cover-inner{
    min-height:100vh; display:flex; flex-direction:column; justify-content:space-between;
    padding:40px 32px 20px; position:relative; overflow:hidden;
  }
  #cover .cover-inner::after{
    content:"";
    position:absolute; inset:18px;
    border:1px solid rgba(232,224,203,0.18);
    pointer-events:none;
  }
  .cover-top{
    display:flex; justify-content:space-between; align-items:flex-start;
    font-family:'IBM Plex Mono'; font-size:12px; letter-spacing:.08em;
    text-transform:uppercase; color:rgba(232,224,203,0.6);
  }
  .cover-mid{margin:auto 0; padding:64px 0 24px;}
  .cover-mid .eyebrow{color:var(--gold); margin-bottom:18px; display:block;}
  .cover-title{
    font-size:clamp(52px, 10vw, 118px);
    font-weight:700;
    letter-spacing:-0.01em;
    color:var(--paper-hi);
  }
  .cover-title em{
    font-style:italic; font-weight:400; color:var(--clay-soft);
  }
  .cover-dek{
    font-family:'Source Serif 4';
    font-size:19px; max-width:520px; margin-top:22px;
    color:rgba(232,224,203,0.82);
  }
  .cover-photo-slot{margin-top:36px;}
  .cover-bottom{
    display:flex; justify-content:space-between; align-items:flex-end;
    font-family:'IBM Plex Mono'; font-size:12px; color:rgba(232,224,203,0.5);
  }

  /* photo / interview placeholders */
  .photo-slot{
    border:1.5px dashed rgba(42,36,25,0.4);
    background:rgba(42,36,25,0.03);
    padding:22px;
    display:flex; flex-direction:column; gap:8px; justify-content:center;
    aspect-ratio: var(--ar, 16/10);
    position:relative;
  }
  .photo-slot .ph-label{
    font-family:'IBM Plex Mono'; font-size:11.5px; letter-spacing:.04em;
    color:var(--charcoal-soft); text-transform:uppercase;
  }
  .photo-slot .ph-suggest{
    font-family:'IBM Plex Mono'; font-size:12px; color:var(--clay);
    line-height:1.5;
  }
  #cover .photo-slot{
    border-color:rgba(232,224,203,0.35);
    background:rgba(232,224,203,0.04);
  }
  #cover .photo-slot .ph-label{color:rgba(232,224,203,0.55);}
  #cover .photo-slot .ph-suggest{color:var(--clay-soft);}

  /* ---------- GENERIC SECTION ---------- */
  .section-front{background:var(--paper); padding:88px 0 20px;}
  .front-head{margin-bottom:34px;}
  .front-head .eyebrow{color:var(--clay); margin-bottom:10px; display:block;}
  .front-head h2{font-size:clamp(32px,5vw,46px);}

  /* ---------- CHAPTER OPENERS (dark) ---------- */
  .chapter-open{
    background:var(--river-deep);
    color:var(--paper-hi);
    min-height:74vh;
    display:flex; flex-direction:column; justify-content:center;
    padding:80px 0 64px;
    position:relative;
  }
  .chapter-open::before{
    content:"";
    position:absolute; inset:0;
    background:radial-gradient(ellipse at 80% 0%, rgba(166,62,44,0.28), transparent 60%);
    pointer-events:none;
  }
  .chapter-num{
    font-family:'IBM Plex Mono'; font-size:13px; letter-spacing:.18em;
    color:var(--gold); margin-bottom:18px;
  }
  .chapter-open h2{
    font-size:clamp(38px,6.4vw,70px);
    color:var(--paper-hi);
    max-width:760px;
  }
  .chapter-dek{
    font-family:'Source Serif 4'; font-style:italic; font-size:19px;
    color:rgba(232,224,203,0.75); max-width:560px; margin-top:20px;
  }
  .chapter-open .photo-slot{
    margin-top:40px; border-color:rgba(232,224,203,0.35);
    background:rgba(232,224,203,0.04); --ar:21/9;
  }
  .chapter-open .photo-slot .ph-label{color:rgba(232,224,203,0.55);}
  .chapter-open .photo-slot .ph-suggest{color:var(--clay-soft);}

  .chapter-body{background:var(--paper); padding:64px 0 0;}
  .lede{font-size:21px; color:var(--charcoal); max-width:660px;}
  .lede + p, p.body-p{margin-top:20px; max-width:660px; color:var(--charcoal-soft); font-size:17.5px;}
  .grid2{display:grid; grid-template-columns:1fr 1fr; gap:28px; margin:36px 0;}
  .grid3{display:grid; grid-template-columns:repeat(3,1fr); gap:20px; margin:36px 0;}

  /* pull quote */
  blockquote.pull{
    border-left:3px solid var(--clay);
    margin:40px 0; padding:4px 0 4px 26px;
    font-family:'Fraunces'; font-style:italic; font-weight:400;
    font-size:26px; line-height:1.35; color:var(--river-deep);
    max-width:640px;
  }
  blockquote.pull cite{
    display:block; font-family:'IBM Plex Mono'; font-style:normal;
    font-size:12px; letter-spacing:.06em; text-transform:uppercase;
    color:var(--charcoal-soft); margin-top:12px;
  }

  /* interview quote-slot for named participants */
  .voice-slot{border-top:1px solid var(--rule); padding-top:18px; margin-top:26px;}
  .voice-slot .who{
    font-family:'IBM Plex Mono'; font-size:12.5px; text-transform:uppercase;
    letter-spacing:.06em; color:var(--clay); margin-bottom:6px;
  }
  .voice-slot .prompt{font-family:'Source Serif 4'; font-style:italic; color:var(--charcoal-soft); font-size:16.5px;}

  /* ---------- TRAIL MARKER STAT PLAQUE ---------- */
  .markers-row{display:flex; flex-wrap:wrap; gap:22px; margin:40px 0;}
  .trail-marker{
    background:var(--river-deep); color:var(--paper-hi);
    border-radius:6px 6px 34px 34px; padding:22px 20px 18px; width:220px;
    position:relative; box-shadow:0 10px 22px rgba(21,42,51,0.28);
    border:1px solid rgba(232,224,203,0.15);
  }
  .trail-marker::before{
    content:""; position:absolute; top:10px; left:50%; transform:translateX(-50%);
    width:22px; height:22px; border:1px solid var(--gold); border-radius:50%; opacity:.55;
  }
  .trail-marker .tm-eyebrow{font-family:'IBM Plex Mono'; font-size:10px; letter-spacing:.12em; text-transform:uppercase; color:var(--gold); margin-top:26px; text-align:center;}
  .trail-marker .tm-num{font-family:'Fraunces'; font-weight:700; font-size:34px; text-align:center; margin-top:6px; color:var(--paper-hi);}
  .trail-marker .tm-label{font-family:'IBM Plex Mono'; font-size:11px; text-align:center; color:rgba(232,224,203,0.7); margin-top:4px; line-height:1.4;}
  .trail-marker .tm-source{font-family:'IBM Plex Mono'; font-size:9px; text-align:center; color:rgba(232,224,203,0.4); margin-top:12px; letter-spacing:.02em;}

  /* ================= MUSEUM EXHIBIT MODULES ================= */
  /* used for chapters built from photos/video/interviews captured on-site at museums */
  .museum-wall{
    background:var(--museum-bg); color:var(--paper-hi);
    padding:72px 0; position:relative; margin-top:8px;
  }
  .museum-wall::before{
    content:""; position:absolute; inset:0;
    background:radial-gradient(ellipse at 50% -10%, rgba(201,154,61,0.14), transparent 55%);
    pointer-events:none;
  }
  .museum-wall .eyebrow{color:var(--gold); position:relative;}
  .museum-h{
    font-family:'Fraunces'; font-weight:900; text-transform:uppercase;
    letter-spacing:-0.01em; font-size:clamp(32px,5.6vw,58px);
    color:var(--clay-soft); line-height:0.98; margin:10px 0 14px; position:relative;
  }
  .museum-sub{
    font-family:'IBM Plex Mono'; font-size:13px; line-height:1.7;
    color:rgba(241,234,217,0.62); max-width:560px; margin-bottom:38px; position:relative;
  }
  .museum-grid{display:grid; grid-template-columns:repeat(5,1fr); gap:6px; margin:0 0 12px; position:relative;}
  .m-tile{aspect-ratio:1; padding:12px; display:flex; flex-direction:column; justify-content:flex-end; position:relative; overflow:hidden;}
  .m-tile.photo{background:linear-gradient(155deg, var(--t1), var(--t2));}
  .m-tile.photo.sepia{--t1:#6b5636; --t2:#cbb98a;}
  .m-tile.photo.green{--t1:#1c2f22; --t2:#4c7658;}
  .m-tile.photo.blue{--t1:#16232c; --t2:#3c6070;}
  .m-tile.photo .m-label{
    font-family:'IBM Plex Mono'; font-size:8.5px; text-transform:uppercase; letter-spacing:.05em;
    color:rgba(255,255,255,.92); background:rgba(0,0,0,.4); padding:4px 6px; align-self:flex-start; line-height:1.4;
  }
  .m-tile.placard{justify-content:center;}
  .m-tile.placard.navy{background:#1f3a52;}
  .m-tile.placard.rust{background:var(--clay);}
  .m-tile.placard.olive{background:#5c4a24;}
  .m-tile.placard h4{font-family:'Fraunces'; font-size:14px; color:#f4ecd8; text-transform:uppercase; letter-spacing:.03em; margin-bottom:6px;}
  .m-tile.placard p{font-family:'IBM Plex Mono'; font-size:10px; line-height:1.5; color:rgba(244,236,216,.82); margin:0;}
  .museum-caption{
    font-family:'IBM Plex Mono'; font-size:11px; color:rgba(241,234,217,0.45);
    margin-top:8px; position:relative;
  }

  /* museum display case: artifact / interview quote pairing */
  .museum-case{
    display:grid; grid-template-columns:1fr 1fr;
    border:1px solid rgba(241,234,217,.14); margin:34px 0; position:relative;
  }
  .case-artifact{
    background:#0e0b08; padding:28px; display:flex; flex-direction:column; gap:10px;
    justify-content:center; align-items:flex-start;
  }
  .case-artifact .ph-label{color:rgba(241,234,217,.55); font-family:'IBM Plex Mono'; font-size:11px; text-transform:uppercase; letter-spacing:.05em;}
  .case-artifact .ph-suggest{color:var(--clay-soft); font-family:'IBM Plex Mono'; font-size:11.5px; line-height:1.6;}
  .case-quote{background:#38431f; padding:28px; display:flex; flex-direction:column; justify-content:center;}
  .case-quote p{font-family:'Fraunces'; font-style:italic; font-size:18px; color:#f4ecd8; line-height:1.42; margin:0;}
  .case-quote cite{display:block; margin-top:14px; font-family:'IBM Plex Mono'; font-size:10.5px; color:rgba(244,236,216,.6); font-style:normal; text-transform:uppercase; letter-spacing:.05em;}

  /* timeline / history-at-a-glance cards */
  .history-band{background:#161210; padding:56px 0; position:relative;}
  .history-cards{display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-top:10px;}
  .h-card{background:var(--museum-card); border:1px solid rgba(241,234,217,.08); padding:16px;}
  .h-card .yr{font-family:'IBM Plex Mono'; color:var(--gold); font-size:11.5px; margin-bottom:6px;}
  .h-card .place{font-family:'Fraunces'; font-size:16px; color:#f4ecd8; margin-bottom:8px;}
  .h-card p{font-family:'IBM Plex Mono'; font-size:10.5px; color:rgba(241,234,217,.6); line-height:1.55; margin:0 0 8px;}
  .h-card .toll{font-family:'IBM Plex Mono'; font-size:10px; color:var(--clay-soft); border-top:1px solid rgba(241,234,217,.1); padding-top:8px;}

  /* ---------- TOC ---------- */
  #toc-front{background:var(--ink); color:var(--paper-hi);}
  #toc-front .front-head .eyebrow{color:var(--gold);}
  #toc-front .front-head h2{color:var(--paper-hi);}
  .toc-table{width:100%; border-collapse:collapse; margin-top:20px;}
  .toc-table tr{border-bottom:1px solid rgba(232,224,203,0.14); cursor:pointer;}
  .toc-table tr:hover td{color:var(--gold);}
  .toc-table td{padding:16px 6px; vertical-align:baseline; transition:color .15s;}
  .toc-table .tnum{font-family:'IBM Plex Mono'; font-size:13px; color:var(--gold); width:44px;}
  .toc-table .ttitle{font-family:'Fraunces'; font-size:21px; font-weight:600;}
  .toc-table .ttitle small{display:block; font-family:'Source Serif 4'; font-style:italic; font-weight:400; font-size:14.5px; color:rgba(232,224,203,0.55); margin-top:2px;}
  .toc-table .tpages{font-family:'IBM Plex Mono'; font-size:12.5px; color:rgba(232,224,203,0.55); text-align:right; white-space:nowrap;}
  .toc-budget{margin-top:26px; padding-top:16px; border-top:1px solid rgba(232,224,203,0.25); display:flex; justify-content:space-between; font-family:'IBM Plex Mono'; font-size:13px; color:rgba(232,224,203,0.7);}
  .toc-budget b{color:var(--gold);}

  /* ---------- FOOTER / CLOSING ---------- */
  #closing{background:var(--ink); color:var(--paper-hi);}
  #closing .front-head .eyebrow{color:var(--gold);}
  #closing .front-head h2{color:var(--paper-hi);}
  #closing .body-p, #closing .lede{color:rgba(232,224,203,0.78);}
  #closing .photo-slot{border-color:rgba(232,224,203,0.3); background:rgba(232,224,203,0.04);}
  #closing .photo-slot .ph-label{color:rgba(232,224,203,0.5);}
  .team-grid{display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-top:28px;}
  .team-card{border:1px solid rgba(232,224,203,0.18); padding:16px; font-family:'IBM Plex Mono'; font-size:12px; color:rgba(232,224,203,0.6);}
  .team-card .name{font-family:'Fraunces'; font-size:16px; color:var(--paper-hi); margin-bottom:4px;}
  .back-cover{background:var(--river-deep); color:var(--paper-hi); padding:90px 0; text-align:center; margin-top:20px;}
  .back-cover h3{font-size:clamp(28px,4vw,38px); max-width:640px; margin:0 auto 22px;}
  .praise{font-family:'Fraunces'; font-style:italic; font-size:20px; max-width:560px; margin:0 auto 12px; color:rgba(232,224,203,0.85);}
  .praise cite{display:block; font-family:'IBM Plex Mono'; font-style:normal; font-size:11px; margin-top:8px; color:var(--gold); text-transform:uppercase; letter-spacing:.06em;}
  footer.credits{background:var(--ink); color:rgba(232,224,203,0.4); font-family:'IBM Plex Mono'; font-size:11.5px; padding:26px 0 40px; text-align:center;}

  #builder-note{
    background:var(--gold); color:var(--ink); font-family:'IBM Plex Mono'; font-size:12.5px;
    padding:10px 16px 10px 80px; line-height:1.5; position:relative; z-index:400;
  }
  #builder-note b{text-transform:uppercase; letter-spacing:.05em;}
  #builder-note button{background:var(--ink); color:var(--gold); border:none; font-family:'IBM Plex Mono'; font-size:11px; padding:4px 10px; cursor:pointer; margin-left:10px; border-radius:3px;}

  @media (max-width:760px){
    #spine{top:auto; bottom:0; left:0; right:0; height:56px; width:100%; flex-direction:row; padding:0 8px; border-right:none; border-top:1px solid rgba(232,224,203,0.08); z-index:600;}
    #spine .mark{display:none;}
    #spine-list{flex-direction:row; overflow-x:auto; overflow-y:visible; align-items:center; height:100%;}
    #spine-list li a{height:100%; padding:0 12px; white-space:nowrap;}
    #spine-list li a.active::before{left:6px; right:6px; top:auto; bottom:6px; height:2px; width:auto;}
    main{margin-left:0; padding-bottom:56px;}
    .grid2, .grid3{grid-template-columns:1fr;}
    .team-grid{grid-template-columns:repeat(2,1fr);}
    .museum-grid{grid-template-columns:repeat(2,1fr);}
    .history-cards{grid-template-columns:1fr 1fr;}
    .museum-case{grid-template-columns:1fr;}
    #builder-note{padding-left:16px;}
  }
</style>
</head>
<body>

<div id="builder-note">
  <b>Prototype note —</b> Dashed boxes mark where your real photography and transcribed interviews go. Dark "museum wall" panels are styled after the exhibit photos you shared — swap the tinted tiles for your own on-site photos/video stills. Numbers in the plaques are real, sourced stats. <button onclick="document.getElementById('builder-note').style.display='none'">Dismiss</button>
</div>

<nav id="spine">
  <div class="mark" onclick="showTab('cover')">DI</div>
  <ul id="spine-list">
    <li><a data-tab="cover">Cvr</a></li>
    <li><a data-tab="intro">In</a></li>
    <li><a data-tab="toc-front">Toc</a></li>
    <li><a data-tab="directors-note">Dn</a></li>
    <li><a data-tab="voices">Vo</a></li>
    <li><a data-tab="ch-mississippi">01</a></li>
    <li><a data-tab="ch-education">02</a></li>
    <li><a data-tab="ch-healthcare">03</a></li>
    <li><a data-tab="ch-immigrants">04</a></li>
    <li><a data-tab="ch-faiths">05</a></li>
    <li><a data-tab="ch-blues">06</a></li>
    <li><a data-tab="ch-civilrights">07</a></li>
    <li><a data-tab="ch-media">08</a></li>
    <li><a data-tab="ch-commemoration">09</a></li>
    <li><a data-tab="closing">Cl</a></li>
  </ul>
</nav>

<main>

  <!-- ============ COVER ============ -->
  <section id="cover" class="tab-panel" data-dark="true">
   <div class="cover-inner">
    <div class="cover-top">
      <span>The Delta Issue</span>
      <span>Vol. 04 — Documentary Workshop Publication</span>
    </div>
    <div class="cover-mid wrap" style="padding-left:0;padding-right:0;max-width:100%;">
