            <div class="tm-eyebrow">Poverty rate</div>
            <div class="tm-num">17.8%</div>
            <div class="tm-label">Mississippi statewide, 2024 — highest in the U.S.</div>
            <div class="tm-source">Source: U.S. Census / USAFacts, 2024</div>
          </div>
          <div class="trail-marker">
            <div class="tm-eyebrow">Delta counties</div>
            <div class="tm-num">30–40%</div>
            <div class="tm-label">Poverty rate in most Delta counties</div>
            <div class="tm-source">Source: BLS county data, 2022–23</div>
          </div>
          <div class="trail-marker">
            <div class="tm-eyebrow">Cotton, 1930</div>
            <div class="tm-num">4.16M</div>
            <div class="tm-label">Acres planted statewide — Mississippi's historic peak</div>
            <div class="tm-source">Source: Mississippi Encyclopedia</div>
          </div>
          <div class="trail-marker">
            <div class="tm-eyebrow">Cotton, 2023</div>
            <div class="tm-num">395K</div>
            <div class="tm-label">Acres planted — a fraction of the historic peak</div>
